# Database (SQLite - local file, no setup required)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth / Auth.js (required - generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Anthropic (required for scanning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe (optional - leave blank to disable payment UI)
# Create products at dashboard.stripe.com, then copy price IDs
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
